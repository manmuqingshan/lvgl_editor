<globals>
	<api>
		<!-- No project-wide enums needed by the doc examples. -->
	</api>

	<consts>
		<!-- Accent used by labels that sit on top of a filled indicator
		     (bar, slider) where the default text color would be hard to read. -->
		<color name="color_text_on_fill" value="0x013992" help="Label color over filled widgets" />
	</consts>

	<styles>
		<!-- Add shared <style> tags here when 2+ examples need the same look. -->
	</styles>

	<subjects>
		<!-- Generic subjects reused by every data-binding example so each
		     screen doesn't have to invent its own subject names. -->
		<int name="subject_value" value="50" min_value="0" max_value="100" help="Generic 0..100 value" />
		<int name="subject_value2" value="20" min_value="0" max_value="100" help="Second generic 0..100 value" />
		<int name="subject_opa" value="128" min_value="0" max_value="255" help="Generic opacity 0..255" />
		<int name="subject_index" value="0" help="Generic selected index" />
		<int name="subject_checked" value="0" help="Generic on/off (0 or 1) for switches and checkboxes" />
		<string name="subject_text" value="Hello" help="Generic string value" />
	</subjects>

	<images>
		<!-- Small 48x48 logo reused by the image-based examples. -->
		<data name="img_logo" src_path="images/img_logo.png" color_format="argb8888" />
		<data name="imgbtn_left" src_path="images/imgbtn_left.png" color_format="argb8888"/>
		<data name="imgbtn_mid" src_path="images/imgbtn_mid.png" color_format="argb8888"/>
		<data name="imgbtn_right" src_path="images/imgbtn_right.png" color_format="argb8888"/>
		<data name="img_bulb" src_path="images/bulb.gif" color_format="raw"/>
	</images>

	<fonts>
		<bin name="font_large" src_path="fonts/Montserrat-Medium.ttf" size="28" bpp="4" as_file="false" />
	</fonts>
</globals>
