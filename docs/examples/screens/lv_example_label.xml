<!--
 @title Label
 @brief Recoloring, a long-text mode and a value bound to a subject.

 A plain heading sits on top. Below it, one label uses `recolor="true"` so
 `#hex text#` spans change colour inline. The next is given a fixed width with
 `long_mode="scroll_circular"` so the over-long text scrolls continuously. The
 last uses `bind_text` with a `bind_text-fmt` printf string to track
 `subject_value` live.
-->
<screen>
	<styles>
		<style
			name="style_box"
			bg_color="0x1f2937"
			bg_opa="100%"
			radius="8"
			pad_all="10"
			text_color="0xe5e7eb"
			width="260"
		/>
	</styles>

	<view
		flex_flow="column"
		style_pad_row="12"
		style_bg_color="0xfa6"
		style_flex_cross_place="center"
		style_flex_main_place="center"
		style_flex_track_place="center"
		style_grid_column_dsc_array="50 fr(1) 2fr content"
		style_grid_row_dsc_array="100"
		style_layout="grid"
	>
		<!-- 💡 The scrolling label's text is wider than its fixed width, so it loops. -->
		<lv_button
			style_grid_cell_column_pos="0"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		>
			<lv_label text="1" align="center" />
		</lv_button>
		<lv_button
			style_grid_cell_column_pos="1"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		>
			<lv_label text="2" align="center" />
		</lv_button>
		<lv_button
			style_grid_cell_column_pos="2"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		>
			<lv_label text="3" align="center" />
		</lv_button>
		<lv_button
			width="150"
			style_grid_cell_column_pos="3"
			style_grid_cell_row_pos="0"
			style_grid_cell_x_align="stretch"
			style_grid_cell_y_align="stretch"
		>
			<lv_label text="4" align="center" />
		</lv_button>
	</view>
</screen>
