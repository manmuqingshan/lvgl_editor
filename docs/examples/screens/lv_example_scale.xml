<!--
 @title Scale
 @brief A round and a horizontal scale, each with a coloured danger section.

 The first scale uses `mode="round_inner"` to draw a circular scale; the
 second uses `mode="horizontal_bottom"`. `total_tick_count`, `major_tick_every`
 (and `angle_range` on the round one) shape the ticks, and `label_show` prints
 values. On each, a `<lv_scale-section>` restyles the 80–100 range via named
 styles to mark a danger zone.
-->
<screen>
	<styles>
		<style
			name="style_scale_main"
			bg_color="0x0f172a"
			bg_opa="100%"
			pad_all="14"
			arc_color="0x64748b"
			line_color="0x64748b"
			text_color="0xcbd5e1"
		/>

		<style name="style_scale_minor_ticks" line_color="0x64748b" length="6" />
		<style name="style_scale_major_ticks" line_color="0x3577d3" line_width="3" length="10" />

		<!-- Danger section styling -->
		<style name="style_danger_line" line_color="0xef4444" arc_color="0xef4444" line_width="4" />
		<style name="style_danger_ind" line_color="0xef4444" line_width="4" text_color="0xef4444" />
		<style name="style_danger_items" line_color="0xf87171" line_width="3" />
	</styles>

	<view>
		<lv_scale
			width="170"
			height="170"
			y="-40"
			align="center"
			mode="round_inner"
			min_value="0"
			max_value="100"
			total_tick_count="21"
			major_tick_every="5"
			angle_range="270"
			rotation="135"
			label_show="true"
			style_radius="100"
		>
			<style name="style_scale_main" />
			<style name="style_scale_minor_ticks" selector="items" />
			<style name="style_scale_major_ticks" selector="indicator" />

			<lv_scale-section
				min_value="80"
				max_value="100"
				style_main="style_danger_line"
				style_indicator="style_danger_ind"
				style_items="style_danger_items"
			/>
		</lv_scale>

		<lv_scale
			width="220"
			height="60"
			y="80"
			align="center"
			mode="horizontal_bottom"
			min_value="0"
			max_value="100"
			total_tick_count="21"
			major_tick_every="5"
			label_show="true"
			style_radius="10"
			style_transform_rotation-indicator="450"
			style_pad_bottom-indicator="6"
		>
			<style name="style_scale_main" />
			<style name="style_scale_minor_ticks" selector="items" />
			<style name="style_scale_major_ticks" selector="indicator" />

			<lv_scale-section
				min_value="80"
				max_value="100"
				style_main="style_danger_line"
				style_indicator="style_danger_ind"
				style_items="style_danger_items"
			/>
		</lv_scale>
	</view>
</screen>
