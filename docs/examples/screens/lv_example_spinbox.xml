<!--
 @title Spinbox
 @brief A fixed-point spinbox and a bound one linked to a slider.

 The first spinbox sets `digit_count` and `dec_point_pos` for a fixed
 decimal point, with a `min_value`/`max_value` range, a `step`, and
 `rollover="true"` so it wraps at the limits. The second uses
 `bind_value="subject_value"`; a slider bound to the same subject moves it.
-->
<screen>
	<styles>
		<style
			name="style_sb"
			bg_color="0x111827"
			bg_opa="100%"
			text_color="0xf9fafb"
			radius="8"
			pad_all="10"
			text_font="font_large"
		/>
	</styles>

	<view
		flex_flow="column"
		style_pad_row="16"
		style_pad_all="16"
		style_flex_cross_place="center"
		style_flex_track_place="center"
		style_flex_main_place="center"
	>
		<!-- Fixed-point: 4 digits, point 2 places from the right -->
		<lv_spinbox
			width="150"
			digit_count="4"
			dec_point_pos="2"
			min_value="0"
			max_value="9999"
			step="25"
			rollover="true"
			value="1250"
		>
			<style name="style_sb" />
		</lv_spinbox>

		<!-- Bound to subject_value, driven by the slider below -->
		<lv_spinbox width="150" min_value="0" max_value="100" bind_value="subject_value">
			<style name="style_sb" />
		</lv_spinbox>

		<lv_slider width="220" bind_value="subject_value" />
	</view>
</screen>
